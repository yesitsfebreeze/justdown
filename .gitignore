# local secrets — assembly secrets store, never commit
.assembly.env
.assembly.env:Zone.Identifier

# pi agent runtime (auth/settings are local-only)
.pi/

# OS metadata
*:Zone.Identifier
.DS_Store
Thumbs.db

# common build/output dirs referenced by example recipes
dist/
node_modules/
.vite.pid

# rust cli build output
cli/target/

# .bombshell is the per-repo derived layer (vendored clones, built index,
# vectors/ratings cache) — fully local, rebuilt by `jd build`, never committed.
.bombshell/

# A stray `jd build` against a stale binary or wrong JUSTDOWN_INDEX can drop an
# index at the repo root — never legitimate, so ignore it.
/graph.db

# kern runtime (local-only graph memory)
.kern/

# local Claude Code MCP wiring (kern etc.) — environment-specific
.mcp.json

# Obsidian vault config — local editor metadata, never part of the project
.obsidian/

# vicky knowledge base — plugin-managed local KB, environment-specific
vicky/

# Claude Code session state (local settings, history, plans, task scratch) —
# harness-local, never part of the project.
.claude/

# git-fs plugin's local snapshot store — a separate, unrelated git history;
# never part of the project and must never be committed or pushed.
.git-fs/

# session safety-net file (owning session id) — harness-local, never committed.
.claude-session

# mesh plugin runtime roster/state — local-only, rebuilt per session.
.mesh/

# cargo workspace build output
/target/
